{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build && node scripts/strip-module-type.mjs",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "github": {
    "silent": false
  }
}
