{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build && node scripts/strip-module-type.mjs",
  "functions": {
    "api/**/*.{js,cjs}": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/monthly-backup",
      "schedule": "0 14 1 * *"
    }
  ],
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "github": {
    "silent": false
  }
}
