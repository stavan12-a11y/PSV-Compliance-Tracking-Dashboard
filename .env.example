# ---------------------------------------------------------------------------
# Copy to ".env" for local development, or set these in your host (e.g. Vercel,
# Netlify). Vite only exposes variables prefixed with VITE_.
# ---------------------------------------------------------------------------

# --- Cloud mode (shared, live data for a team) -----------------------------
# When BOTH are set, the app uses Supabase: a real login, one shared dataset,
# and real-time sync so everyone sees the same data. See supabase/schema.sql
# for the one-time database setup, then create a user in Supabase Auth.
# VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Local mode (single static login, per-browser data) --------------------
# Used only when Supabase is NOT configured. Defaults: admin / boiler-2026.
# VITE_APP_USERNAME=admin
# VITE_APP_PASSWORD=choose-a-strong-password
