# ---------------------------------------------------------------------------
# Copy to ".env" for local development, or set these in Vercel (Production).
# See docs/NEON_SETUP.md for step-by-step setup (no coding required).
# ---------------------------------------------------------------------------

# --- Cloud mode (recommended): Vercel API + Neon ---------------------------
# Client flag — must be true in production for shared team data.
# VITE_CLOUD_MODE=true

# Server-only (set in Vercel, NOT in .env.local for the browser):
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
# TEAM_USERNAME=ues-admin
# TEAM_PASSWORD=choose-a-strong-password
# AUTH_SECRET=at-least-16-random-characters

# --- Monthly Excel backup by email (optional) ---------------------------
# See docs/MONTHLY_BACKUP.md for setup. Runs automatically on the 1st of each month.
# BACKUP_EMAIL_TO=you@example.com
# RESEND_API_KEY=re_...
# CRON_SECRET=another-long-random-string

# --- Local mode (per-browser data, no cloud) -------------------------------
# Used when VITE_CLOUD_MODE is not true.
# VITE_APP_USERNAME=admin
# VITE_APP_PASSWORD=tamu-psv-2026
